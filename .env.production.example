# Cheapest deploy: one VPS (~€4/mo Hetzner CX22) + free Let's Encrypt SSL via Caddy.
#
# Setup:
#   1. Rent a VPS (see README Deploy section)
#   2. Point DNS A records: APP_DOMAIN and API_DOMAIN → VPS IP
#   3. cp .env.production.example .env.production && fill in values
#   4. ./scripts/deploy-vps.sh
#
# Generate secrets:
#   RAILS_MASTER_KEY  — cat api/config/master.key
#   SECRET_KEY_BASE   — cd api && bin/rails secret

# Domains (required for HTTPS)
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Derived URLs — VITE_API_URL is baked into the PWA at build time
VITE_API_URL=https://api.example.com/api/v1
CORS_ORIGINS=https://app.example.com

# Secrets
DB_PASSWORD=change-me-to-a-long-random-string
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# Optional: comma-separated hosts Rails accepts (defaults to API_DOMAIN in compose)
ALLOWED_HOSTS=
