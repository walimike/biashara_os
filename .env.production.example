# Copy to .env.production for docker compose prod deploys.
# Generate secrets:
#   RAILS_MASTER_KEY  — contents of api/config/master.key
#   SECRET_KEY_BASE   — cd api && bin/rails secret

DB_PASSWORD=change-me
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# Browser-facing API URL (baked into the PWA at build time)
VITE_API_URL=http://localhost:3000/api/v1

# Must match the public URL where the PWA is served
CORS_ORIGINS=http://localhost:8080

API_PORT=3000
WEB_PORT=8080
